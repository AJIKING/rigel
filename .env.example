# 実値は .env / .dev.vars に入れる（コミットしない。.gitignore 済み）。
# AI 呼び出しは Cloudflare AI Gateway 経由（キャッシュ・コスト監視・流量制御）。

# Gemini API キー
GEMINI_API_KEY=

# Cloudflare AI Gateway の google-ai-studio ベースURL（/v1beta/... の手前まで）
CLOUDFLARE_AI_GATEWAY_URL=

# 読み取りモデル（任意。AI Studio で現行モデルを確認して設定。未指定なら既定値）
GEMINI_RIVER_MODEL=
GEMINI_HAND_MODEL=

# 認証（api / Workers）
GOOGLE_CLIENT_ID=
SESSION_SECRET=

# 課金（Stripe サブスク。4つ揃わなければ /billing/* は 501＝無効）
STRIPE_SECRET_KEY=       # sk_... または rk_...（Secret。チャット等に貼ったら必ずローテーション）
STRIPE_WEBHOOK_SECRET=   # whsec_...（Webhook 署名検証用・Secret）
STRIPE_PRICE_NEXT=       # price_...（RIGEL Next ¥480・公開値）
STRIPE_PRICE_PRO=        # price_...（RIGEL Pro ¥1480・公開値）

# web (Next.js) のクライアント公開変数（apps/web/.env.local に置く）
# NEXT_PUBLIC_API_URL=          # api のベースURL（未設定なら同一オリジン）
# NEXT_PUBLIC_GOOGLE_CLIENT_ID= # Google ログイン用クライアントID

# mobile (Expo) のクライアント公開変数（apps/mobile/.env に置く）
# EXPO_PUBLIC_API_URL=          # api のベースURL
# EXPO_PUBLIC_GOOGLE_CLIENT_ID= # Google OAuth Web クライアントID（id_token フロー用）
